PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/kemalreis?retryWrites=true&w=majority
CLIENT_ORIGINS=http://localhost:5173
NODE_ENV=development

# Amazon Reviews 2023 demo catalog import
AMAZON_CATALOG_TARGET=2000
AMAZON_CATALOG_USER_AGENT=Kemalreis/0.1 (https://github.com/Miles70/kemalreis)

# Professional catalog translation pipeline
# Page requests never translate live. Run the catalog worker before publishing products.
TRANSLATION_PROVIDER=deepl
TRANSLATION_TIMEOUT_MS=30000
DEEPL_API_KEY=

# Optional custom endpoint. Leave empty; :fx keys automatically use api-free.deepl.com.
DEEPL_API_URL=

# Optional per-language DeepL glossary IDs for protected product terminology.
DEEPL_GLOSSARY_ID_TR=
DEEPL_GLOSSARY_ID_RU=
DEEPL_GLOSSARY_ID_AR=
DEEPL_GLOSSARY_ID_ZH=

# Keep concurrency low until usage and cost behavior is verified.
CATALOG_TRANSLATION_CONCURRENCY=1
CATALOG_TRANSLATION_DELAY_MS=150
